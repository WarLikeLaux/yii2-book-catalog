{
    "name": "warlikelaux/yii2-book-catalog",
    "description": "Book catalog showcase on Yii2 with Clean Architecture, DDD, CQS, and PHP 8.5",
    "keywords": [
        "yii2",
        "book-catalog",
        "clean-architecture",
        "ddd",
        "cqs"
    ],
    "homepage": "https://github.com/WarLikeLaux/yii2-book-catalog",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/WarLikeLaux/yii2-book-catalog/issues",
        "source": "https://github.com/WarLikeLaux/yii2-book-catalog"
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.5.0",
        "yiisoft/yii2": "~2.0.54",
        "yiisoft/yii2-bootstrap5": "~2.0.2",
        "yiisoft/yii2-symfonymailer": "~2.0.3",
        "yiisoft/yii2-queue": "^2.3",
        "vlucas/phpdotenv": "^5.5",
        "psr/log": "^3.0",
        "kartik-v/yii2-widget-select2": "^2.2",
        "giggsey/libphonenumber-for-php": "^9.0",
        "yiisoft/yii2-redis": "^2.1",
        "guzzlehttp/guzzle": "^7.10",
        "inspector-apm/inspector-php": "^3.16",
        "npm-asset/faker": "5.5.3",
        "twbs/bootstrap-icons": "^1.13",
        "npm-asset/glightbox": "^3.3",
        "npm-asset/htmx.org": "^2.0",
        "jolicode/automapper": "^9.5",
        "open-telemetry/sdk": "^1.13",
        "open-telemetry/exporter-otlp": "^1.4",
        "oscarotero/env": "^2.1",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "npm-asset/prettier": "^3.7.4",
        "symfony/var-dumper": "^8.0",
        "yiisoft/yii2-debug": "~2.1.0",
        "yiisoft/yii2-gii": "~2.2.0",
        "yiisoft/yii2-faker": "~2.0.0",
        "codeception/codeception": "^5.0.0 || ^4.0",
        "codeception/lib-innerbrowser": "^4.0 || ^3.0 || ^1.1",
        "codeception/module-asserts": "^3.0 || ^1.1",
        "codeception/module-yii2": "^1.1",
        "codeception/module-filesystem": "^3.0 || ^2.0 || ^1.1",
        "codeception/module-webdriver": "^4.0 || ^3.0 || ^1.2",
        "codeception/verify": "^3.0 || ^2.2",
        "squizlabs/php_codesniffer": "^4.0",
        "yiisoft/yii2-coding-standards": "^3.0",
        "slevomat/coding-standard": "^8.25",
        "phpstan/phpstan": "^2.1",
        "deptrac/deptrac": "4.x-dev",
        "infection/infection": "^0.32.0",
        "infection/codeception-adapter": "^0.4.4",
        "rector/rector": "^2.3",
        "zircote/swagger-php": "^5.0",
        "codeception/module-rest": "^3.4",
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "buggregator/trap": "^1.15",
        "phpro/grumphp": "^2.18",
        "dg/bypass-finals": "^1.9",
        "psy/psysh": "^0.12.18",
        "symfony/yaml": "^7.4",
        "phparkitect/phparkitect": "^0.8"
    },
    "autoload": {
        "psr-4": {
            "app\\": ["src/", ""],
            "Tools\\": "tools/"
        },
        "files": [
            "tools/PHPUnit/Framework/Attributes/CodeCoverageIgnore.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "phpro/grumphp": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        },
        "process-timeout": 1800,
        "default-socket-timeout": 120,
        "fxp-asset": {
            "enabled": false
        }
    },
    "scripts": {
        "post-install-cmd": [
            "yii\\composer\\Installer::postInstall"
        ],
        "post-create-project-cmd": [
            "yii\\composer\\Installer::postCreateProject",
            "yii\\composer\\Installer::postInstall"
        ]
    },
    "extra": {
        "yii\\composer\\Installer::postCreateProject": {
            "setPermission": [
                {
                    "runtime": "0777",
                    "web/assets": "0777",
                    "yii": "0755"
                }
            ]
        },
        "yii\\composer\\Installer::postInstall": {
            "generateCookieValidationKey": [
                "config/web.php"
            ]
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org",
            "options": {
                "http": {
                    "timeout": 120
                }
            }
        }
    ]
}
