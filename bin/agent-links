#!/usr/bin/env bash

set -euo pipefail

readonly ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
readonly SOURCE_FILE="CLAUDE.md"

readonly SYMLINKS=(
    "GEMINI.md"
    "AGENTS.md"
    "GROK.md"
    ".cursorrules"
    ".clinerules"
    ".windsurfrules"
)

readonly NESTED_DIRS=(
    ".agent/rules:rules.md"
)

cd "$ROOT_DIR"

if [[ ! -f "$SOURCE_FILE" ]]; then
    echo "⚠️  Файл $SOURCE_FILE не найден. Пропускаю создание симлинков."
    exit 0
fi

echo "🔗 Создание симлинков для AI агентов..."

for link in "${SYMLINKS[@]}"; do
    ln -sf "$SOURCE_FILE" "$link"
done

for entry in "${NESTED_DIRS[@]}"; do
    dir="${entry%%:*}"
    file="${entry##*:}"
    mkdir -p "$dir"

    depth=$(echo "$dir" | tr -cd '/' | wc -c)
    prefix=""
    for ((i = 0; i <= depth; i++)); do
        prefix="../$prefix"
    done

    ln -sf "${prefix}${SOURCE_FILE}" "$dir/$file"
done

derived_paths=()
for entry in "${NESTED_DIRS[@]}"; do
    dir="${entry%%:*}"
    file="${entry##*:}"
    derived_paths+=("$dir/$file")
done

echo "✅ Симлинки созданы: ${SYMLINKS[*]}, ${derived_paths[*]} -> $SOURCE_FILE"

echo "📂 Настройка алиасов для Skills..."
mkdir -p .claude/skills
mkdir -p .codex
mkdir -p .cursor

ln -sfT ../.claude/skills .agent/skills
ln -sfT ../.claude/skills .codex/skills
ln -sfT ../.claude/skills .cursor/skills

mkdir -p "$HOME/.claude" 2>/dev/null || true
ln -sf "$ROOT_DIR/.claude/skills" "$HOME/.claude/skills" 2>/dev/null || true

echo "✅ Алиасы для skills настроены: .agent/skills, .codex/skills, ~/.claude/skills -> .claude/skills"
