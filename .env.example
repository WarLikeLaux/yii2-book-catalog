# Настройки приложения

YII_DEBUG=true
YII_ENV=dev
COOKIE_VALIDATION_KEY=changeme

# База данных

# Переключатель: mysql | pgsql
DB_DRIVER=mysql

# MySQL
MYSQL_DB_HOST=db
MYSQL_DB_PORT=3306
MYSQL_PUBLIC_PORT=33060

# PostgreSQL
PGSQL_DB_HOST=pgsql
PGSQL_DB_PORT=5432
PGSQL_PUBLIC_PORT=54320

# Общие
DB_NAME=yii2basic
DB_USER=yii2
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root
POSTGRES_USER=yii2

# Redis

REDIS_HOST=redis
REDIS_PORT=6379

# Публичный порт (host:6379 -> container:6379)
REDIS_PUBLIC_PORT=6379

# Mailer

MAILER_HOST=127.0.0.1
MAILER_PORT=1025
MAILER_USE_FILE_TRANSPORT=true

# Docker services

UID=1000
GID=1000

# Ports
APP_PORT=8000
SWAGGER_PORT=8081

# API keys

SMS_API_KEY=MOCK_KEY
SMS_IDEMPOTENCY_HASH_KEY=changeme

# Rate limiting

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

